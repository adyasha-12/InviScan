{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "An invitation or event scanned by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "isNew": { "type": "boolean" },
        "notificationEnabled": { "type": "boolean" },
        "notificationTime": { "type": "string" },
        "image": { "type": "string", "description": "Base64 encoded image or URL" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "notes": { "type": "string" },
        "aiSuggestions": { "type": "string" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "location", "date", "userId"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "joinedDate": { "type": "string" },
        "scannedCount": { "type": "integer" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "events/{eventId}": {
      "schema": "Event",
      "description": "Collection of scanned events."
    }
  }
}
